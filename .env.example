# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic — Claude Sonnet handles all LLM generation steps
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — text-embedding-3-small for ChromaDB indexing
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Cohere — rerank-v3.5 for two-stage retrieval
# Get at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# GitHub Personal Access Token — reads repos, issues, and file trees
# Get at: https://github.com/settings/tokens (repo read scope is enough)
GITHUB_PAT=

# ── Optional — LangSmith tracing ──────────────────────────────────────────────
# Set LANGCHAIN_TRACING_V2=true to enable traces in LangSmith dashboard
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=oss-rag

# ── Deployment only ───────────────────────────────────────────────────────────
# Set this in Streamlit Cloud secrets so the frontend points to the deployed backend
# Leave blank for local development (defaults to http://127.0.0.1:8000)
API_URL=
